{
  "name": "@grayhaven/sandcastle",
  "version": "0.1.9",
  "description": "The fastest way to run untrusted JavaScript safely. Zero-config, Bun-first.",
  "license": "(MIT OR Apache-2.0)",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./codemode": {
      "types": "./dist/codemode/index.d.ts",
      "import": "./dist/codemode/index.js"
    },
    "./guest": {
      "types": "./src/guest/index.d.ts"
    }
  },
  "types": "./dist/index.d.ts",
  "bin": {
    "sandcastle": "./bin/sandcastle.cjs"
  },
  "files": [
    "dist",
    "src/guest",
    "scripts",
    "bin",
    "proto"
  ],
  "scripts": {
    "build": "bun run build:js && bun run build:types",
    "build:js": "bun build ./src/index.ts ./src/codemode/index.ts --outdir ./dist --target node --format esm",
    "build:types": "tsc -p tsconfig.build.json",
    "check": "biome check && tsc --noEmit",
    "lint": "biome check src/ test/",
    "lint:fix": "biome check --write src/ test/",
    "format": "biome format --write src/ test/",
    "test": "bun test",
    "postinstall": "node scripts/postinstall.cjs || true",
    "prepublishOnly": "bun run build"
  },
  "peerDependencies": {
    "isolated-vm": "^6.1.2"
  },
  "peerDependenciesMeta": {
    "isolated-vm": {
      "optional": true
    }
  },
  "devDependencies": {
    "@anthropic-ai/sdk": "^0.80.0",
    "@biomejs/biome": "^2.4.9",
    "@types/bun": "latest",
    "typescript": "^5.7.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/tylergibbs1/sandcastle",
    "directory": "sdk/typescript"
  },
  "keywords": [
    "sandbox",
    "v8",
    "isolate",
    "bun",
    "ai",
    "agent",
    "code-execution",
    "sandcastle",
    "eval",
    "secure"
  ]
}
